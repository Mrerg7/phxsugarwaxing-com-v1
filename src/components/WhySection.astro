---
import { getCollection } from 'astro:content';

const valueProps = (await getCollection('valueProps')).sort((a, b) => a.data.order - b.data.order);
---

<section id="why" class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:pb-16">
  <div class="text-center mb-10">
    <div class="modern-pill inline-block mb-3">LOCAL SEO + FULL PHRASE MATCH</div>
    <h2 class="section-header tracking-tight">Why phxsugarwaxing.com is a strong premium asset</h2>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      valueProps.map(({ data }) => (
        <div class="value-card clean-section rounded-3xl p-6 sm:p-8">
          <div class="w-11 h-11 bg-[#F8F1E9] rounded-2xl flex items-center justify-center mb-6">
            <i class={`fa-solid ${data.icon} text-[#B85C38] text-xl`}></i>
          </div>
          <h3 class="font-semibold text-lg sm:text-xl tracking-tight mb-3">{data.title}</h3>
          <p class="text-[#5C5C5C] leading-relaxed text-sm sm:text-base">{data.description}</p>
        </div>
      ))
    }
  </div>
</section>

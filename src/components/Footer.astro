---
import { ACQUISITION_MAILTO, DISCLAIMER_DATE, SITE } from '../config/site';
---

<footer class="relative z-10 border-t border-[#EDE4D7] bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Sophisticated Domain Acquisition CTA -->
    <div
      class="relative overflow-hidden rounded-3xl border border-[#B85C38]/25 bg-gradient-to-br from-[#2D2D2D] via-zinc-900 to-[#B85C38]/20 p-6 sm:p-10 lg:p-12 mb-10 sm:mb-12 text-white"
    >
      <div
        class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-[#B85C38]/15 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full bg-[#A04E30]/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 grid lg:grid-cols-[1.2fr_0.8fr] gap-8 lg:gap-10 items-center">
        <div>
          <p class="text-xs uppercase tracking-[3px] text-[#E8A07A] font-extrabold mb-4">
            Domain Available for Acquisition
          </p>
          <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl tracking-tight mb-4">
            phxsugarwaxing.com — A Premium Phoenix Digital Asset
          </h2>
          <p class="text-zinc-300 max-w-xl leading-relaxed text-sm sm:text-base">
            Positioned at the intersection of Phoenix local search, natural beauty branding, and sugar waxing
            expertise, this domain delivers full-phrase keyword alignment and instant service clarity. Serious buyers
            may inquire for pricing, transfer logistics, and escrow options.
          </p>
        </div>

        <div
          class="rounded-2xl p-6 sm:p-8 border border-white/10 bg-black/40 backdrop-blur-md"
        >
          <p class="text-xs uppercase tracking-[2px] text-zinc-400 font-semibold mb-2">Acquisition Contact</p>
          <a
            href={`mailto:${SITE.email}`}
            class="block text-xl sm:text-2xl lg:text-3xl font-display text-white hover:text-[#E8A07A] transition-colors break-all"
          >
            {SITE.email}
          </a>
          <a
            href={ACQUISITION_MAILTO}
            class="mt-6 inline-flex w-full items-center justify-center gap-x-3 px-6 py-4 bg-gradient-to-r from-[#B85C38] to-[#A04E30] text-white font-extrabold rounded-2xl hover:brightness-110 transition-all active:scale-[0.985]"
          >
            <span>Inquire About Acquisition</span>
            <i class="fa-solid fa-arrow-right"></i>
          </a>
          <p class="mt-4 text-[11px] text-zinc-400 text-center tracking-wide">
            Confidential inquiries &bull; Response within 24 hours
          </p>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-xs text-[#6B6B6B] leading-relaxed max-w-4xl mb-8 sm:mb-10">
      This website is for demonstration and informational purposes only. It does not constitute an offer of services,
      a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
      technologies are based on publicly available information as of {DISCLAIMER_DATE} and are subject to change.
    </p>

    <!-- Bottom bar -->
    <div
      class="pt-6 sm:pt-8 border-t border-[#EDE4D7] text-xs text-[#6B6B6B] flex flex-col md:flex-row gap-y-3 items-center justify-between"
    >
      <div>phxsugarwaxing.com is a premium domain currently available for acquisition.</div>
      <div class="text-center md:text-right">Local SEO &bull; Natural beauty positioning &bull; Strong brand clarity</div>
    </div>
  </div>
</footer>
